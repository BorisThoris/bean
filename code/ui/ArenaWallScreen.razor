@using Sandbox
@using Sandbox.UI
@using System
@using System.Linq
@inherits PanelComponent

<root class="arena-wall-screen">
	@if ( Game.IsValid() )
	{
		var state = Game.GetWallScreenState();
		var leaders = state.Leaders.Length > 0
			? state.Leaders
			: state.Stations
				.Where( x => x.CssClass != "open" )
				.OrderByDescending( x => x.Score )
				.Select( ( station, index ) => new TapperWallLeaderboardDisplay( index + 1, station.Name, station.SteamId, station.Score, station.Speed, Math.Max( 0, 4 - index ), station.CssClass == "winner" ) )
				.ToArray();
		var top = leaders.FirstOrDefault();
		var rest = leaders.Skip( 1 ).Take( 3 ).ToArray();
		var hasLeader = leaders.Length > 0;
		var maxScore = Math.Max( 1, leaders.Length > 0 ? leaders.Max( x => x.Score ) : state.Stations.Max( x => x.Score ) );
		var maxSpeed = Math.Max( 1f, leaders.Length > 0 ? leaders.Max( x => x.PeakSpeed ) : state.Stations.Max( x => x.Speed ) );
		var stationCountClass = $"station-count-{Math.Clamp( state.Stations.Length, 1, 8 )}";
		var headlineClass = $"headline {GetHeadlineFitClass( state.Headline )}";
		var titleClass = $"title {GetSingleLineFitClass( state.Title, 18 )}";
		var modeClass = $"match-pill {GetSingleLineFitClass( state.ModeName, 10 )}";

		<div class=@($"screen-shell {stationCountClass}")>
			<div class="top-bar">
				<div class="brand-block">
					<div class=@titleClass>@state.Title</div>
					<div class="subtitle">@state.EventPhase</div>
				</div>
				<div class="match-strip">
					<div class=@modeClass>@state.ModeName</div>
					<div class="match-pill">ROUND @state.TournamentRound/@state.TournamentRounds</div>
					<div class="match-pill">@state.ClaimedStations CLAIMED</div>
				</div>
			</div>

			<div class="arena-board">
				<div class="content-row">
					<div class="hero-panel">
						<div class=@headlineClass>@state.Headline</div>
						<div class="timer-row">
							<span>@state.RoundState</span>
							<strong>@Math.Max( 0, Math.Ceiling( state.TimeRemaining ) ).ToString( "00" )</strong>
						</div>
						<div class="round-meter">
							<div style=@($"width: {Percent( state.RoundProgress )}%")></div>
						</div>
					</div>

					<div class="leaderboard-panel">
						<div class="panel-title">
							<span>LEADERBOARD</span>
							<small>LIVE</small>
						</div>

						@if ( hasLeader )
						{
							<div class=@($"leader-champion {(top.Winner ? "winner" : "")}")>
								<div class=@AvatarClass( top.SteamId, "avatar avatar-large" ) style=@AvatarStyle( top.SteamId )>
									<span>@GetInitials( top.Name )</span>
								</div>
								<div class="champion-copy">
									<div class="champion-kicker">#@top.Rank CURRENT LEADER</div>
									<div class="champion-name">@top.Name</div>
									<div class="champion-stats">
										<span>@top.Score taps</span>
										<span>@top.PeakSpeed.ToString( "0.0" )/s peak</span>
										<span>@top.Points pts</span>
									</div>
								</div>
							</div>

							<div class="leader-list">
								@foreach ( var leader in rest )
								{
									<div class=@($"leader-row {(leader.Winner ? "winner" : "")}")>
										<div class="rank">@leader.Rank</div>
										<div class=@AvatarClass( leader.SteamId, "avatar" ) style=@AvatarStyle( leader.SteamId )>
											<span>@GetInitials( leader.Name )</span>
										</div>
										<div class="leader-identity">
											<div class="leader-name">@leader.Name</div>
											<div class="leader-subline">@leader.Points pts</div>
										</div>
										<div class="leader-metrics">
											<strong>@leader.Score</strong>
											<span>@leader.PeakSpeed.ToString( "0.0" )/s</span>
										</div>
										<div class="leader-bars">
											<i style=@($"width: {Percent( leader.Score / (float)maxScore )}%")></i>
											<b style=@($"width: {Percent( leader.PeakSpeed / maxSpeed )}%")></b>
										</div>
									</div>
								}
							</div>
						}
						else
						{
							<div class="empty-leaderboard">CLAIM A PLATFORM TO JOIN</div>
						}
					</div>
				</div>

				<div class=@($"station-grid {stationCountClass}")>
					@foreach ( var row in state.Stations )
					{
						<div class=@($"station-card {row.CssClass}")>
							<div class="station-top">
								<span>@row.Station</span>
								<strong>@row.Status</strong>
							</div>
							<div class="station-player">
								<div class=@AvatarClass( row.SteamId, "avatar avatar-small" ) style=@AvatarStyle( row.SteamId )>
									<span>@GetInitials( row.Name )</span>
								</div>
								<div class="station-name">@row.Name</div>
							</div>
							<div class="station-stats">
								<span>@row.Score taps</span>
								<span>@row.Speed.ToString( "0.0" )/s</span>
							</div>
							<div class="mini-meters">
								<div><i style=@($"width: {Percent( row.Progress )}%")></i></div>
								<div><b style=@($"width: {Percent( row.Heat )}%")></b></div>
							</div>
						</div>
					}
				</div>
			</div>

			<div class="bottom-band">
				<span>@state.Mode</span>
				<span>@state.RoundState</span>
			</div>
		</div>
	}
	else
	{
		<div class="screen-shell boot">
			<div class="headline">TAPPER ARENA</div>
		</div>
	}
</root>

@code
{
	[Property] public PhysicalFastestTapperGame Game { get; set; }

	private static float Percent( float value )
	{
		return MathF.Round( value.Clamp( 0f, 1f ) * 100f );
	}

	private static string GetInitials( string name )
	{
		if ( string.IsNullOrWhiteSpace( name ) || name == "OPEN" )
			return "--";

		var parts = name.Split( ' ', StringSplitOptions.RemoveEmptyEntries );
		if ( parts.Length == 0 )
			return name.Length > 1 ? name[..2].ToUpper() : name.ToUpper();

		var first = parts[0][0].ToString();
		var second = parts.Length > 1 ? parts[1][0].ToString() : "";
		var initials = first + second;
		return initials.ToUpper();
	}

	private static string AvatarClass( string steamId, string baseClass )
	{
		return string.IsNullOrWhiteSpace( steamId ) ? baseClass : $"{baseClass} has-image";
	}

	private static string AvatarStyle( string steamId )
	{
		return string.IsNullOrWhiteSpace( steamId ) ? "" : $"background-image: url( avatar:{steamId} )";
	}

	private static string GetHeadlineFitClass( string headline )
	{
		if ( string.IsNullOrWhiteSpace( headline ) )
			return "short";

		var lines = headline.Split( '\n' );
		var longest = lines.Length == 0 ? headline.Length : lines.Max( x => x.Length );
		if ( lines.Length >= 3 || longest > 14 )
			return "compact";

		if ( lines.Length > 1 || longest > 9 )
			return "stacked";

		return "short";
	}

	private static string GetSingleLineFitClass( string text, int compactAfter )
	{
		return string.IsNullOrWhiteSpace( text ) || text.Length <= compactAfter ? "normal" : "compact";
	}

	protected override int BuildHash()
	{
		if ( !Game.IsValid() )
			return 0;

		var state = Game.GetWallScreenState();
		var hash = HashCode.Combine( state.Title, GetSingleLineFitClass( state.Title, 18 ), state.Headline, GetHeadlineFitClass( state.Headline ), state.Mode, state.RoundState, state.EventPhase );
		hash = HashCode.Combine( hash, state.ModeName, GetSingleLineFitClass( state.ModeName, 10 ), state.TournamentRound, state.TournamentRounds, state.ClaimedStations );
		hash = HashCode.Combine( hash, state.Stations.Length, state.TimeRemaining, state.RoundProgress );

		foreach ( var row in state.Stations )
		{
			hash = HashCode.Combine( hash, row.Station, row.Name, row.SteamId, row.Status, row.Score );
			hash = HashCode.Combine( hash, row.Speed, row.Progress, row.Heat, row.CssClass );
		}

		foreach ( var leader in state.Leaders )
			hash = HashCode.Combine( hash, leader.Rank, leader.Name, leader.SteamId, leader.Score, leader.PeakSpeed, leader.Points, leader.Winner );

		return hash;
	}
}
