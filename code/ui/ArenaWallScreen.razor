@using Sandbox
@using Sandbox.UI
@using System
@inherits PanelComponent
@attribute [StyleSheet( "code/ui/ArenaWallScreen.scss" )]

<root class="arena-wall-screen">
	@if ( Game.IsValid() )
	{
		<div class="screen-shell">
			<div class="top-bar">
				<div class="title">@Game.GetWallScreenTitle()</div>
				<div class="top-meta">
					<div class="debug-badge">@Game.GetWallScreenHtmlDebugText()</div>
					<div class="mode">@Game.GetWallScreenModeText()</div>
				</div>
			</div>

			<div class="main">
				<div class="headline">@Game.GetWallScreenHeadline()</div>
				<div class="leaderboard">@Game.GetWallScreenLeaderboardText()</div>
			</div>

			<div class="station-grid">
				@foreach ( var row in Game.GetWallScreenStationRows() )
				{
					<div class=@($"station-row {row.CssClass}")>
						<div class="station">@row.Station</div>
						<div class="name">@row.Name</div>
						<div class="status">@row.Status</div>
						<div class="meta">@row.Meta</div>
					</div>
				}
			</div>
		</div>
	}
	else
	{
		<div class="screen-shell boot">
			<div class="headline">TAPPER ARENA</div>
		</div>
	}
</root>

@code
{
	[Property] public PhysicalFastestTapperGame Game { get; set; }

	protected override void OnUpdate()
	{
		StateHasChanged();
	}
}
